--- a/dlls/wlanapi/main.c	2026-06-11 19:52:08
+++ b/dlls/wlanapi/main.c	2026-06-11 18:10:54
@@ -38,6 +38,44 @@
 
 #define WLAN_MAGIC 0x574c414e /* WLAN */
 
+/* AiM: a fixed GUID for the single synthetic Wi-Fi interface we present to RS3. */
+static const GUID AIM_WLAN_GUID = { 0xa1ada1a1, 0x0000, 0x0000, { 0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x01 } };
+
+/* AiM: wlanapi.h in Wine doesn't define the current-connection structs (current_connection was
+ * never implemented). Define the Windows SDK layout here so WlanQueryInterface can answer the
+ * wlan_intf_opcode_current_connection poll RS3 spins on. */
+typedef enum _WLAN_CONNECTION_MODE { wlan_connection_mode_profile = 0 } AIM_WLAN_CONNECTION_MODE;
+#define AIM_DOT11_SSID_MAX_LENGTH 32
+typedef struct _AIM_DOT11_SSID { ULONG uSSIDLength; UCHAR ucSSID[AIM_DOT11_SSID_MAX_LENGTH]; } AIM_DOT11_SSID;
+typedef UCHAR AIM_DOT11_MAC_ADDRESS[6];
+typedef struct _AIM_WLAN_ASSOCIATION_ATTRIBUTES {
+    AIM_DOT11_SSID dot11Ssid;
+    int dot11BssType;            /* DOT11_BSS_TYPE: 1 = infrastructure */
+    AIM_DOT11_MAC_ADDRESS dot11Bssid;
+    int dot11PhyType;            /* DOT11_PHY_TYPE: 7 = HT */
+    ULONG uDot11PhyIndex;
+    ULONG wlanSignalQuality;     /* 0..100 */
+    ULONG ulRxRate;
+    ULONG ulTxRate;
+} AIM_WLAN_ASSOCIATION_ATTRIBUTES;
+typedef struct _AIM_WLAN_SECURITY_ATTRIBUTES {
+    BOOL bSecurityEnabled;
+    BOOL bOneXEnabled;
+    int dot11AuthAlgorithm;      /* 1 = open */
+    int dot11CipherAlgorithm;    /* 0 = none */
+} AIM_WLAN_SECURITY_ATTRIBUTES;
+typedef struct _AIM_WLAN_CONNECTION_ATTRIBUTES {
+    WLAN_INTERFACE_STATE isState;
+    AIM_WLAN_CONNECTION_MODE wlanConnectionMode;
+    WCHAR strProfileName[256];
+    AIM_WLAN_ASSOCIATION_ATTRIBUTES wlanAssociationAttributes;
+    AIM_WLAN_SECURITY_ATTRIBUTES wlanSecurityAttributes;
+} AIM_WLAN_CONNECTION_ATTRIBUTES;
+
+/* The dash's AP SSID. RS3 only needs to believe Wi-Fi is associated; the dash IP is derived
+ * from the host route (10.0.0.1 on the dash AP), not from here. */
+static const char AIM_SSID[] = "AiM-Dash";
+
 static struct wine_wlan
 {
     DWORD magic, cli_version;
@@ -74,7 +112,7 @@
     struct wine_wlan *wlan;
     WLAN_INTERFACE_INFO_LIST *ret_list;
 
-    FIXME("(%p, %p, %p) semi-stub\n", handle, reserved, interface_list);
