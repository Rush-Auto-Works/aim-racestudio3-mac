+    ret_list->InterfaceInfo[0].InterfaceGuid = AIM_WLAN_GUID;
+    lstrcpyW(ret_list->InterfaceInfo[0].strInterfaceDescription, L"AiM Wi-Fi (Wine)");
+    ret_list->InterfaceInfo[0].isState = wlan_interface_state_connected;
+    ret_list->dwNumberOfItems = 1;
+    ret_list->dwIndex = 0;
     *interface_list = ret_list;
 
     return ERROR_SUCCESS;
@@ -167,10 +212,50 @@
 DWORD WINAPI WlanQueryInterface(HANDLE handle, const GUID *guid, WLAN_INTF_OPCODE opcode,
                     void *reserved, DWORD *data_size, void **data, WLAN_OPCODE_VALUE_TYPE *opcode_type)
 {
-    FIXME("(%p, %s, 0x%x, %p, %p, %p, %p) stub\n",
+    FIXME("(%p, %s, 0x%x, %p, %p, %p, %p) AiM\n",
           handle, wine_dbgstr_guid(guid), opcode, reserved, data_size, data, opcode_type);
 
-    return ERROR_CALL_NOT_IMPLEMENTED;
+    if (!handle || reserved || !data_size || !data)
+        return ERROR_INVALID_PARAMETER;
+    if (!handle_index(handle))
+        return ERROR_INVALID_HANDLE;
+
+    /* AiM: RS3 spins on current_connection waiting to be "connected". Report a connected
+     * infrastructure association to the dash SSID so it proceeds to aim-ka discovery. */
+    if (opcode == wlan_intf_opcode_current_connection)
+    {
+        AIM_WLAN_CONNECTION_ATTRIBUTES *conn = WlanAllocateMemory(sizeof(*conn));
+        if (!conn) return ERROR_NOT_ENOUGH_MEMORY;
+        DWORD i;
+        memset(conn, 0, sizeof(*conn));
+        conn->isState = wlan_interface_state_connected;
+        conn->wlanConnectionMode = wlan_connection_mode_profile;
+        for (i = 0; i < sizeof(AIM_SSID) && i < ARRAY_SIZE(conn->strProfileName) - 1; i++)
+            conn->strProfileName[i] = (WCHAR)(unsigned char)AIM_SSID[i]; /* ASCII -> WCHAR */
+        conn->wlanAssociationAttributes.dot11Ssid.uSSIDLength = sizeof(AIM_SSID) - 1;
+        memcpy(conn->wlanAssociationAttributes.dot11Ssid.ucSSID, AIM_SSID, sizeof(AIM_SSID) - 1);
+        conn->wlanAssociationAttributes.dot11BssType = 1;   /* infrastructure */
+        conn->wlanAssociationAttributes.dot11PhyType = 7;   /* HT */
+        conn->wlanAssociationAttributes.wlanSignalQuality = 90;
+        conn->wlanAssociationAttributes.ulRxRate = 65000;
+        conn->wlanAssociationAttributes.ulTxRate = 65000;
+        *data = conn;
+        *data_size = sizeof(*conn);
+        if (opcode_type) *opcode_type = wlan_opcode_value_type_query_only;
+        return ERROR_SUCCESS;
+    }
+    if (opcode == wlan_intf_opcode_interface_state)
+    {
+        WLAN_INTERFACE_STATE *st = WlanAllocateMemory(sizeof(*st));
+        if (!st) return ERROR_NOT_ENOUGH_MEMORY;
+        *st = wlan_interface_state_connected;
+        *data = st;
+        *data_size = sizeof(*st);
+        if (opcode_type) *opcode_type = wlan_opcode_value_type_query_only;
+        return ERROR_SUCCESS;
+    }
+
+    return ERROR_NOT_SUPPORTED;
 }
 
