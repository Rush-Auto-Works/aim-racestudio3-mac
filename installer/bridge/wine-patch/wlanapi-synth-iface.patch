     if (!handle || reserved || !interface_list)
         return ERROR_INVALID_PARAMETER;
@@ -87,9 +125,16 @@
     if (!ret_list)
         return ERROR_NOT_ENOUGH_MEMORY;
 
+    /* AiM: macOS Wi-Fi cannot be enumerated through Wine (no native wlanapi backend), so RS3's
+     * CThreadWlanScan sees zero interfaces and never starts dash discovery. Present ONE synthetic
+     * interface, already "connected", so RS3 proceeds to aim-ka discovery — which the patched
+     * ws2_32 + the root aim-bridge daemon then carry to the real dash over loopback. */
     memset(&ret_list->InterfaceInfo[0], 0, sizeof(WLAN_INTERFACE_INFO));
-    ret_list->dwNumberOfItems = 0;
