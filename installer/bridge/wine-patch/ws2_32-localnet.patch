 {
     struct afd_connect_params *params;
     IO_STATUS_BLOCK io;
     HANDLE sync_event;
     NTSTATUS status;
+    struct sockaddr_in aim_tmp;
 
     TRACE( "socket %#Ix, addr %s, len %d\n", s, debugstr_sockaddr(addr), len );
+    addr = aim_loopback_redirect( addr, len, &aim_tmp );
 
     if (!(sync_event = get_sync_event())) return -1;
 
