+/* AiM WiFi loopback redirect (macOS Local Network gate workaround).
+ * The AP-mode AiM dash is 10.0.0.0/28, which the macOS 15+/26 Local Network privacy gate
+ * silently drops for the Wine guest. Redirect those sockets to 127.0.0.1, where the notarized
+ * root aim-bridge daemon relays to the real dash. Only 10.0.0.0/28 is touched; all other
+ * traffic is unaffected. See aim-racestudio3-mac installer/bridge/. */
+static const struct sockaddr *aim_loopback_redirect( const struct sockaddr *addr, int len,
+                                                     struct sockaddr_in *tmp )
+{
+    if (addr && len >= (int)sizeof(*tmp) && addr->sa_family == AF_INET)
+    {
+        const unsigned char *b = (const unsigned char *)&((const struct sockaddr_in *)addr)->sin_addr;
+        if (b[0] == 10 && b[1] == 0 && b[2] == 0 && b[3] <= 15) /* 10.0.0.0/28 */
+        {
+            unsigned char *d = (unsigned char *)&tmp->sin_addr;
+            *tmp = *(const struct sockaddr_in *)addr;
+            d[0] = 127; d[1] = 0; d[2] = 0; d[3] = 1; /* 127.0.0.1 */
+            FIXME( "AiM: redirecting %s to 127.0.0.1\n", debugstr_sockaddr(addr) );
+            return (const struct sockaddr *)tmp;
+        }
+    }
+    return addr;
+}
+
