# pins.env — the VERIFIED, pinned combination this installer ships by default.
# Sourced by installer-core.sh. Every value here was proven end-to-end this session
# (Apple Silicon, macOS 26, Wine 11.9 staging, RaceStudio 3 3.83.20). `--latest` opts
# out of these pins and is flagged unverified.
#
# Do NOT inline these into command strings. They are referenced as array argv only.

# --- Wine (Gcenx macOS staging build) ---
WINE_PINNED_VER="11.9"
WINE_PINNED_URL="https://github.com/Gcenx/macOS_Wine_builds/releases/download/11.9/wine-staging-11.9-osx64.tar.xz"
WINE_PINNED_SIZE=189942264
WINE_PINNED_SHA256="8729601835659814de4c284d33a234a90da50913fa6e6fca260f90e0b2ba8bb2"

# --- RaceStudio 3 (AiM Sportline) ---
RS3_PINNED_VER="3.83.20"
RS3_PINNED_FILE="RaceStudio3-64_38320_000000_000000_20260528_145224.exe"
RS3_PINNED_URL="https://www.aim-sportline.com/aim-software-betas/Software/Applications/WebUpdater/release/RaceStudio3-64_38320_000000_000000_20260528_145224.exe"
RS3_PINNED_SIZE=345795344
RS3_PINNED_SHA256="6f3b74cac4b473fe5022f37e0574035fbae76486d5a56a3627b2c8dfa88dd368"
# AiM release/download page (fallback: open it and let the user grab the latest):
RS3_DOWNLOAD_PAGE="https://www.aim-sportline.com/docs/racestudio3/html/release/download-release.html"

# --- Where RS3 lands inside the Windows prefix ---
RS3_WIN_DIR='C:\AIM_SPORT\RaceStudio3'
RS3_WIN_EXE='C:\AIM_SPORT\RaceStudio3\64\AiMRS3-64-ReleaseU.exe'
# POSIX path of the same exe, relative to the prefix's drive_c:
RS3_REL_EXE="AIM_SPORT/RaceStudio3/64/AiMRS3-64-ReleaseU.exe"
# Fresh-install user-data dir inside the prefix (the symlink source):
RS3_REL_USER="AIM_SPORT/RaceStudio3/user"

# --- macOS install locations ---
APP_SUPPORT="$HOME/Library/Application Support/RaceStudio3"
DATA_DIR_DEFAULT="$HOME/Documents/AIM_SPORT"
DATA_DIR_NONSYNCED="$HOME/AIM_SPORT"          # offered if iCloud Desktop&Documents sync detected
APPS_DIR="/Applications/AiM"                   # group AiM apps in /Applications (overridable; installer falls back to ~/Applications if /Applications isn't writable)
LAUNCHER_APP="$APPS_DIR/RaceStudio 3.app"
UNINSTALL_APP="$APPS_DIR/Uninstall RaceStudio 3.app"
IMPORT_APP="$APPS_DIR/Import RaceStudio 3 Data.app"

# --- Sizing / timeouts ---
MIN_FREE_GB=5
WINE_DOWNLOAD_TIMEOUT=1800     # 30 min — large tarball on slow links
RS3_DOWNLOAD_TIMEOUT=2400      # 40 min — 345 MB installer
WINEBOOT_TIMEOUT=300
SILENT_INSTALL_TIMEOUT=1200    # 20 min — MSI unpack under Rosetta
