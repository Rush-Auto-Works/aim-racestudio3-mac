@@ -220,6 +220,38 @@ - (void) dealloc
         [super dealloc];
     }
 
+    /* RaceStudio 3 add-on: shared launcher for the standalone helper apps that ship beside
+       RaceStudio 3.app in /Applications/AiM. Launch via /usr/bin/open (universal, no deprecated
+       NSWorkspace API; runs the .app natively even though winemac runs x86_64-under-Rosetta).
+       /Applications first, then the per-user fallback the engine uses when /Applications isn't
+       writable. Menu actions run on the main thread — safe for AppKit/NSTask. */
+    - (void) wine_rs3OpenAuxApp:(NSString*)appName
+    {
+        NSArray<NSString*>* roots = @[@"/Applications/AiM",
+                                      [NSHomeDirectory() stringByAppendingPathComponent:@"Applications/AiM"]];
+        for (NSString* root in roots)
+        {
+            NSString* path = [root stringByAppendingPathComponent:appName];
+            if ([[NSFileManager defaultManager] fileExistsAtPath:path])
+            {
+                @try { [NSTask launchedTaskWithLaunchPath:@"/usr/bin/open" arguments:@[path]]; }
+                @catch (NSException *e) { NSBeep(); }
+                return;
+            }
+        }
+        NSBeep();   /* neither location present — should not happen for an installed app */
+    }
+
+    - (void) wine_rs3ImportData:(id)sender
+    {
+        [self wine_rs3OpenAuxApp:@"Import RaceStudio 3 Data.app"];
+    }
+
+    - (void) wine_rs3Uninstall:(id)sender
+    {
+        [self wine_rs3OpenAuxApp:@"Uninstall RaceStudio 3.app"];
+    }
+
     - (void) transformProcessToForeground:(BOOL)activateIfTransformed
     {
         if ([NSApp activationPolicy] != NSApplicationActivationPolicyRegular)
@@ -264,6 +296,18 @@ - (void) transformProcessToForeground:(BOOL)activateIfTransformed
 
             [submenu addItem:[NSMenuItem separatorItem]];
 
